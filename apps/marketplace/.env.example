# Marketplace environment.
# Copy to `.env.local` and fill in to enable features. All are optional in dev.

# API origin the storefront fetches from (defaults to http://localhost:4000).
API_URL=http://localhost:4000

# --- Social sign-in (optional) ---------------------------------------------
# When set, the auth screen uses the real provider SDKs and the API verifies
# the returned ID token. When unset, the buttons fall back to a simulated
# handshake so local dev still works.
#
# Google: an OAuth 2.0 Web client ID from Google Cloud Console. Add your dev
# origin (e.g. http://localhost:3200) to "Authorized JavaScript origins".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Apple: the Services ID from your Apple Developer account, with this origin
# registered as a Return URL / domain for Sign in with Apple.
NEXT_PUBLIC_APPLE_CLIENT_ID=
