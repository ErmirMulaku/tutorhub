    "lint": "eslint src"
  },
  "dependencies": {
    "@ermulaku/types": "*",
    "@reduxjs/toolkit": "2.12.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-redux": "9.3.0",
    "react-router-dom": "7.18.0",
    "socket.io-client": "4.8.3"
  },
  "devDependencies": {
    "@svgr/webpack": "8.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "css-loader": "7.1.4",
    "html-webpack-plugin": "5.6.7",
    "mini-css-extract-plugin": "2.10.2",
    "style-loader": "4.0.0",
    "ts-loader": "9.6.1",
    "webpack": "5.107.2",
    "webpack-bundle-analyzer": "5.3.0",
    "webpack-cli": "7.0.3",
    "webpack-dev-server": "5.2.5"
  }
