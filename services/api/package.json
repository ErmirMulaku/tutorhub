{
  "name": "@ermulaku/api",
  "version": "0.0.0",
  "private": true,
  "description": "TutorHub API — NestJS service exposing the domain over REST (GraphQL + gRPC land in later phases).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src test",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:e2e": "NODE_OPTIONS=--experimental-vm-modules jest --config jest-e2e.config.cjs",
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@apollo/server": "5.5.1",
    "@as-integrations/express5": "1.1.2",
    "@nestjs/apollo": "13.4.2",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/graphql": "13.4.2",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/swagger": "11.4.4",
    "@prisma/adapter-pg": "7.8.0",
    "@ermulaku/slot-engine": "*",
    "@ermulaku/types": "*",
    "@grpc/grpc-js": "1.14.4",
    "@grpc/proto-loader": "0.8.1",
    "@nestjs/microservices": "11.1.27",
    "@nestjs/platform-socket.io": "11.1.27",
    "@nestjs/websockets": "11.1.27",
    "@prisma/client": "7.8.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "dotenv": "17.4.2",
    "graphql": "16.14.2",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.27",
    "socket.io-client": "4.8.3",
    "@types/express": "5.0.6",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "tsx": "4.22.4"
  }
}
