// TutorHub domain model (SPEC §8). One source of truth for Postgres; the
// generated client is consumed by the NestJS service layer.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum NotificationType {
  BOOKING_CONFIRMED
  LESSON_REMINDER
  REVIEW_PROMPT
  GIFT_RECEIVED
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

enum PayoutSchedule {
  DAILY
  WEEKLY
  MONTHLY
}

model Tutor {
  id           String     @id @default(uuid())
  name         String
  bio          String?
  headline     String? // one-line pitch shown on cards/profile
  about        String? // long-form profile/settings bio (distinct from short bio)
  timezone     String // IANA, e.g. "Europe/Belgrade"
  hourlyCents  Int
  workingHours Json // WorkingHours[] — [{ day, start, end }]
  isActive     Boolean    @default(true)
  avatarColor  String? // UI avatar palette key (teal, amber, …)
  languages    String[]   @default([])
  badges       String[]   @default([]) // e.g. "Top rated", "Fast responder", "Verified"
  responseTime String? // human label, e.g. "~1 hr"
  totalLessons Int        @default(0)

  // Tutor identity (dashboard auth). Nullable so seeded tutors and dev-login work
  // without credentials; student auth is unaffected.
  email         String? @unique
  passwordHash  String?
  emailVerified Boolean @default(false)

  // Tutor-side notification preferences (settings → notifications).
  notifyBookings  Boolean @default(true)
  notifyReminders Boolean @default(true)
  notifyMessages  Boolean @default(true)
  notifyPayouts   Boolean @default(true)
  notifyTips      Boolean @default(false)

  // Booking rules (availability module).
  bufferMinutes    Int            @default(15)
  minNoticeHours   Int            @default(4)
  maxLessonsPerDay Int            @default(6)
  payoutSchedule   PayoutSchedule @default(WEEKLY)

  subjects    Subject[]
  bookings    Booking[]
  reviews     Review[]
  favoritedBy Favorite[]
  createdAt   DateTime   @default(now())
}

model Subject {
  id       String    @id @default(uuid())
  name     String
  level    Level
  tutor    Tutor     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  tutorId  String
  bookings Booking[]
}

model Student {
  id           String          @id @default(uuid())
  fullName     String
  email        String          @unique
  passwordHash String? // null for seeded/dev students (dev-login)
  phone        String?
  avatarColor  String? // UI avatar palette key
  walletCents  Int             @default(0)
  // Notification preferences (account → notifications screen).
  notifyEmail     Boolean @default(true)
  notifySms       Boolean @default(false)
  notifyReminders Boolean @default(true)
  notifyPromos    Boolean @default(false)
  twoFactorEnabled Boolean @default(false)
  emailVerified   Boolean @default(false)
  bookings        Booking[]
  favorites       Favorite[]
  giftCards       GiftCard[]
  paymentMethods  PaymentMethod[]
  notifications   Notification[]
  emailCodes      EmailVerification[]
  oauthAccounts   OAuthAccount[]
  createdAt       DateTime        @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  type      NotificationType
  // Denormalised params the client renders into localised title/body templates.
  actorName String? // tutor or gift sender, e.g. "Priya", "Mum"
  detail    String? // subject or amount, e.g. "Computer Science", "$50"
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([studentId, createdAt])
}

model EmailVerification {
  id        String   @id @default(uuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  code      String // 6-digit numeric code
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([studentId])
}

model OAuthAccount {
  id             String        @id @default(uuid())
  provider       OAuthProvider
  providerUserId String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId      String
  createdAt      DateTime      @default(now())

  @@unique([provider, providerUserId])
}

model Favorite {
  id        String   @id @default(uuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  tutor     Tutor    @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  tutorId   String
  createdAt DateTime @default(now())

  @@unique([studentId, tutorId])
}

model GiftCard {
  id          String   @id @default(uuid())
  code        String   @unique
  amountCents Int
  balanceCents Int
  design      Int      @default(0) // index into the UI design palette
  fromName    String?
  toName      String?
  message     String?
  // The student who currently owns/redeemed the card (null = unredeemed).
  owner       Student? @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId     String?
  createdAt   DateTime @default(now())
}

model PaymentMethod {
  id        String   @id @default(uuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  brand     String // "visa", "mastercard", …
  last4     String
  expMonth  Int
  expYear   Int
  createdAt DateTime @default(now())
}

model Booking {
  id        String        @id @default(uuid())
  tutor     Tutor         @relation(fields: [tutorId], references: [id])
  tutorId   String
  student   Student       @relation(fields: [studentId], references: [id])
  studentId String
  subject   Subject       @relation(fields: [subjectId], references: [id])
  subjectId String
  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(PENDING)
  payment   Payment?
  review    Review?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Review {
  id        String  @id @default(uuid())
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String  @unique
  tutor     Tutor   @relation(fields: [tutorId], references: [id])
  tutorId   String
  rating    Int // 1–5
  comment   String?
}

model Payment {
  id          String        @id @default(uuid())
  booking     Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   String        @unique
  amountCents Int
  status      PaymentStatus @default(PENDING)
}
