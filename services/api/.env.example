# Copy to .env (gitignored) and fill in. Never commit real secrets.

# HTTP port the API listens on.
PORT=4000

# PostgreSQL connection string used by Prisma (added in Phase 2 / unit 2).
DATABASE_URL=postgresql://tutorhub:tutorhub@localhost:5432/tutorhub?schema=public

# Secret for signing JWTs (dev-login). Use a long random value in real deploys.
JWT_SECRET=dev-only-change-me

# Social sign-in audiences. When set, googleSignin/appleSignin verify the
# provider ID token against the provider JWKS with this client id as audience.
# Leave unset to disable real social sign-in (the mutations return a
# "not configured" error and the storefront uses its simulated fallback).
# GOOGLE_CLIENT_ID matches NEXT_PUBLIC_GOOGLE_CLIENT_ID; APPLE_CLIENT_ID is the
# Apple Services ID.
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Address the gRPC microservice binds to (SPEC §9).
GRPC_URL=0.0.0.0:50051

# OpenAI booking assistant (SPEC §12B). Leave unset to disable the assistant
# (the /assistant/chat endpoint then returns 503). The key stays server-side.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# The seeded student the assistant books as (no end-user auth yet).
DEMO_STUDENT_EMAIL=sara@example.com

# Stripe (test mode) — powers the real payment loop: students are charged via
# PaymentIntents, funds transfer to each tutor's Connect (Express) account, then
# payouts settle. Leave STRIPE_SECRET_KEY unset to disable payments (the app
# still boots on seeded data). Use TEST keys (sk_test_… / whsec_…) only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Base URL the dashboard is served from — used to build Connect onboarding
# return/refresh redirect links.
DASHBOARD_URL=http://localhost:3100
