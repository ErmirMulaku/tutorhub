{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    // Build against workspace packages' published output (node_modules), not
    // their source — keeps emitted files within rootDir. typecheck still uses
    // the source via the base `paths` for live cross-package types.
    "paths": {}
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/__tests__/**", "test/**/*.ts"]
}
