{
  "name": "@ermulaku/slot-engine",
  "version": "0.1.0",
  "description": "Zero-dependency, timezone- and DST-aware availability slot engine.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "availability",
    "scheduling",
    "timezone",
    "dst",
    "slots",
    "booking",
    "calendar"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  }
}
