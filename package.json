{
  "name": "tutorhub",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "TutorHub — a tutoring/lessons marketplace built as a TypeScript monorepo.",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "26.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.0.7",
    "nx": "23.0.0",
    "prettier": "3.8.4",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1"
  },
  "overrides": {
    "form-data": "4.0.6",
    "tmp": "0.2.7",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "4.2.0"
    }
  }
}
